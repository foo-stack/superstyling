{
  "name": "superstyling-playground",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform dogfooding app for Superstyling (Expo + Expo Router)",
  "license": "MIT",
  "author": "Nathan Irikefe",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "build": "echo 'build: apps do not ship; use expo build or EAS for releases'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@superstyling/core": "workspace:*",
    "@superstyling/expo": "workspace:*",
    "expo": "^54.0.9",
    "expo-router": "^55.0.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "0.83.2"
  }
}
