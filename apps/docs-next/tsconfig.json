{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"]
    },
    "jsx": "react-jsx",
    "types": ["react", "react-dom", "vite/client"],
    "moduleResolution": "Bundler"
  },
  "include": ["app/**/*", "components/**/*", "*.ts", "*.tsx"],
  "exclude": ["node_modules", "dist", ".one"]
}
