{
  "name": "@superstyling/expo",
  "version": "0.0.0",
  "description": "Expo integration for Superstyling — Metro/Babel config, teleport host registration",
  "keywords": [
    "expo",
    "metro",
    "react-native",
    "superstyling"
  ],
  "homepage": "https://github.com/natestack/superstyling/tree/main/packages/expo",
  "license": "MIT",
  "author": "Nathan Irikefe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natestack/superstyling.git",
    "directory": "packages/expo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/setup.js",
    "./dist/setup-all.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js",
      "default": "./dist/setup.js"
    },
    "./setup-all": {
      "types": "./dist/setup-all.d.ts",
      "import": "./dist/setup-all.js",
      "default": "./dist/setup-all.js"
    },
    "./babel-plugin": {
      "types": "./dist/babel-plugin.d.ts",
      "import": "./dist/babel-plugin.js",
      "default": "./dist/babel-plugin.js"
    },
    "./metro-config": {
      "types": "./dist/metro-config.d.ts",
      "import": "./dist/metro-config.js",
      "default": "./dist/metro-config.js"
    },
    "./app-plugin": {
      "types": "./dist/app-plugin.d.ts",
      "import": "./dist/app-plugin.js",
      "default": "./dist/app-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/add-js-extensions.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "echo 'test: not yet implemented (Milestone 2)'"
  },
  "dependencies": {
    "@tamagui/babel-plugin": "2.0.0-rc.41",
    "@tamagui/metro-plugin": "2.0.0-rc.41",
    "@tamagui/native": "2.0.0-rc.41"
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=10.0.0",
    "expo": "^54.0.0 || ^55.0.0",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-teleport": ">=0.5.0",
    "react-native-worklets": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "react-native-teleport": {
      "optional": true
    },
    "react-native-worklets": {
      "optional": true
    }
  }
}
