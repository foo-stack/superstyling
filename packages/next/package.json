{
  "name": "@superstyling/next",
  "version": "0.1.0",
  "description": "Next.js integration for Superstyling — SSR, color mode, plugin wrapper",
  "keywords": [
    "nextjs",
    "react",
    "ssr",
    "superstyling"
  ],
  "homepage": "https://github.com/foo-stack/superstyling/tree/main/packages/next",
  "license": "MIT",
  "author": "Nathan Irikefe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foo-stack/superstyling.git",
    "directory": "packages/next"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "import": "./dist/pages.js",
      "default": "./dist/pages.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/add-js-extensions.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "echo 'test: not yet implemented (Milestone 2)'"
  },
  "dependencies": {
    "@superstyling/core": "workspace:*",
    "@tamagui/next-plugin": "2.0.0-rc.41"
  },
  "devDependencies": {
    "next": "^15"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
