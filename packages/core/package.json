{
  "name": "@superstyling/core",
  "version": "0.1.0",
  "description": "Core components, theme, and style-prop engine for Superstyling",
  "keywords": [
    "chakra",
    "components",
    "cross-platform",
    "design-system",
    "react",
    "react-native",
    "tamagui",
    "ui"
  ],
  "homepage": "https://github.com/foo-stack/superstyling/tree/main/packages/core",
  "license": "MIT",
  "author": "Nathan Irikefe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foo-stack/superstyling.git",
    "directory": "packages/core"
  },
  "bin": {
    "superstyling": "./cli.mjs"
  },
  "files": [
    "dist",
    "cli.mjs",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./colorMode": {
      "types": "./dist/colorMode/index.d.ts",
      "import": "./dist/colorMode/index.js",
      "default": "./dist/colorMode/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/add-js-extensions.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "echo 'test: not yet implemented (Milestone 2)'"
  },
  "dependencies": {
    "@superstyling/icons": "workspace:*",
    "@tamagui/adapt": "2.0.0-rc.41",
    "@tamagui/checkbox": "2.0.0-rc.41",
    "@tamagui/input": "2.0.0-rc.41",
    "@tamagui/label": "2.0.0-rc.41",
    "@tamagui/radio-group": "2.0.0-rc.41",
    "@tamagui/select": "2.0.0-rc.41",
    "@tamagui/sheet": "2.0.0-rc.41",
    "@tamagui/switch": "2.0.0-rc.41"
  }
}
